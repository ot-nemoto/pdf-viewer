{
  "name": "pdf-viewer",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24-bookworm",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  // Vite の dev server を転送してホストのブラウザから確認できるようにする
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite Dev Server",
      "onAutoForward": "openPreview"
    }
  },

  // コンテナ作成後に依存をインストール（package.json がある場合のみ実行）
  "postCreateCommand": "if [ -f package.json ]; then npm install; fi",

  "customizations": {
    "vscode": {
      "extensions": ["biomejs.biome", "ms-vscode.vscode-typescript-next"],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": {
          "source.organizeImports.biome": "explicit",
          "quickfix.biome": "explicit"
        }
      }
    }
  },

  // 公式イメージ同梱の非rootユーザーで動かす
  "remoteUser": "node"
}
