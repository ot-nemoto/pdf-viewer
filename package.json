{
  "name": "pdf-viewer",
  "private": true,
  "version": "0.4.2",
  "type": "module",
  "scripts": {
    "prepare": "biome migrate --write",
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "build:static": "npm run build",
    "preview": "vite preview --host",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
