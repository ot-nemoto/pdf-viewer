{
  "name": "pdf-viewer",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "prepare": "biome migrate --write",
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "build:static": "npm run build",
    "preview": "vite preview --host",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^9.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
